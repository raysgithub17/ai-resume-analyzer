# Site URL used for SEO metadata, sitemap, and Open Graph tags
# Set to your production domain when deploying (e.g. https://your-app.vercel.app)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Hugging Face access token (server-only — never use NEXT_PUBLIC_ prefix)
# Create at: https://huggingface.co/settings/tokens
HF_ACCESS_TOKEN=your_token_here

# Firebase web app config (from Firebase Console > Project settings > Your apps > Web)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
